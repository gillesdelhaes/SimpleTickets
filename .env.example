# ══════════════════════════════════════════════════════════════════════════════
# SimplyTickets — Environment Variables
#
# Only two variables are needed to run the stack.
# All other settings (Slack credentials, app URL, etc.) are configured through
# the first-run setup wizard at http://localhost:3000 and stored in the database.
# ══════════════════════════════════════════════════════════════════════════════

# ── Database ──────────────────────────────────────────────────────────────────
# asyncpg driver URL — points to the 'db' service inside Docker
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/simplytickets

# Password for the postgres container superuser
DB_PASSWORD=postgres
